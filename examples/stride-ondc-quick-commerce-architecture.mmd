    style SignerVerifier fill:#f9f,stroke:#333,stroke-width:2px
    style CallbackHandler fill:#f9f,stroke:#333,stroke-width:2px
    style WebhookV fill:#fcc,stroke:#333,stroke-width:2px
    style RegistryClient fill:#fcc,stroke:#333
    style KMS fill:#9f9,stroke:#333
    style Gateway fill:#fbb,stroke:#333
    style Registry fill:#fbb,stroke:#333
    style Seller fill:#fbb,stroke:#333
    style LSP fill:#fbb,stroke:#333
    style UPIIntent fill:#fbb,stroke:#333
    style Postgres fill:#ff9,stroke:#333
    style Redis fill:#ff9,stroke:#333
    style GCS fill:#ff9,stroke:#333
    style Buyer fill:#bbf,stroke:#333
    style Ops fill:#fbb,stroke:#333
